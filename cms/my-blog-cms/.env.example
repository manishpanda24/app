# Local Mongo (e.g. docker compose up -d in this folder)
DATABASE_URL=mongodb://127.0.0.1:27017/amg-blog-cms

# Remote Atlas (used when MONGO_USE_LOCAL is not set)
# MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/dbname

# If Atlas fails with querySrv ECONNREFUSED (DNS/VPN/firewall), use local Mongo:
# MONGO_USE_LOCAL=true
PAYLOAD_SECRET=replace-with-a-long-random-string
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3001
